# Lala Podman environment
# Copy to lala.podman.env.local and set LALA_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   LALA_PODMAN_ENV=/path/to/lala.podman.env ./scripts/run-lala-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-lala-podman.sh which can generate it).
LALA_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
LALA_PODMAN_GATEWAY_HOST_PORT=18789
LALA_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
LALA_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
